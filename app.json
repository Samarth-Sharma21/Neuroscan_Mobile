{
  "expo": {
    "name": "NeuroScan",
    "slug": "neuroscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "neuroscan",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Capture MRI scans for analysis",
        "NSPhotoLibraryUsageDescription": "Upload MRI scans for analysis"
      }
    },
    "android": {
      "package": "com.neuroscan.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload MRI scans for dementia analysis",
          "cameraPermission": "Capture MRI scans for analysis"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
