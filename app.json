{
  "expo": {
    "name": "NeuroScan",
    "slug": "neuroscan",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "neuroscan",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Capture MRI scans for analysis",
        "NSPhotoLibraryUsageDescription": "Upload MRI scans for analysis"
      }
    },
    "android": {
      "package": "com.neuroscan.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload MRI scans for dementia analysis",
          "cameraPermission": "Capture MRI scans for analysis"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "00aab2fa-5930-4ec9-b138-c347e2d4f84d"
      }
    },
    "owner": "samarth21"
  }
}
